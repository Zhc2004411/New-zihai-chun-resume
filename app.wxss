page {
  min-height: 100vh;
  background: #eef3f8;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text {
  box-sizing: border-box;
}

.muted {
  color: #667085;
}

.tap-card {
  opacity: 0.88;
  transform: scale(0.985);
}

.button-hover {
  opacity: 0.9;
  transform: translateY(2rpx) scale(0.99);
}

@import 'app-wxa-auto-dark.wxss'

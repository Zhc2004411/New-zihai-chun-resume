.page {
  height: 100vh;
  background: linear-gradient(180deg, #e7edf4 0%, #f8fafc 45%, #eef4f7 100%);
}

.hero {
  position: relative;
  height: 650rpx;
  overflow: hidden;
  background: #111827;
  border-bottom-left-radius: 34rpx;
  border-bottom-right-radius: 34rpx;
  box-shadow: 0 20rpx 52rpx rgba(17, 24, 39, 0.18);
}

.hero__image {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero__shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(17, 24, 39, 0.2), rgba(17, 24, 39, 0.72) 48%, rgba(17, 24, 39, 0.98));
}

.hero__content {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 40rpx;
  color: #ffffff;
}

.profile-chip {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  padding: 10rpx 16rpx 10rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.32), 0 14rpx 34rpx rgba(0, 0, 0, 0.16);
  backdrop-filter: blur(18rpx) saturate(150%);
  -webkit-backdrop-filter: blur(18rpx) saturate(150%);
}

.profile-chip__avatar {
  width: 44rpx;
  height: 44rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #f59e0b;
  color: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.profile-chip__text {
  color: #f9fafb;
  font-size: 24rpx;
}

.hero__name {
  display: block;
  margin-top: 28rpx;
  font-size: 68rpx;
  line-height: 1.05;
  font-weight: 900;
}

.hero__role {
  display: block;
  margin-top: 16rpx;
  color: #fde68a;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
}

.hero__slogan {
  display: block;
  margin-top: 12rpx;
  color: #e5e7eb;
  font-size: 27rpx;
  line-height: 1.6;
}

.hero__actions {
  display: flex;
  gap: 18rpx;
  margin-top: 34rpx;
}

.action {
  flex: 1;
  height: 86rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(255, 255, 255, 0.56);
  color: #111827;
  font-size: 28rpx;
  line-height: 86rpx;
  font-weight: 800;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.86), 0 16rpx 36rpx rgba(0, 0, 0, 0.14);
  backdrop-filter: blur(18rpx) saturate(150%);
  -webkit-backdrop-filter: blur(18rpx) saturate(150%);
  transition: transform 160ms ease, opacity 160ms ease;
}

.action::after {
  border: 0;
}

.action--primary {
  background: rgba(245, 158, 11, 0.82);
  border-color: rgba(255, 225, 164, 0.56);
}

.content {
  padding: 0 24rpx 64rpx;
}

.metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: -28rpx;
  position: relative;
  z-index: 2;
}

.metric {
  width: calc(50% - 8rpx);
  padding: 24rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 16rpx 38rpx rgba(17, 24, 39, 0.08);
  backdrop-filter: blur(22rpx) saturate(155%);
  -webkit-backdrop-filter: blur(22rpx) saturate(155%);
  text-align: center;
}

.metric--salary {
  width: 100%;
  padding: 30rpx 20rpx;
  background: rgba(17, 24, 39, 0.84);
  border-color: rgba(255, 255, 255, 0.22);
}

.metric__value {
  display: block;
  color: #111827;
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 900;
}

.metric--salary .metric__value {
  color: #f59e0b;
  font-size: 52rpx;
}

.metric__label {
  display: block;
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
}

.metric--salary .metric__label {
  color: #e5e7eb;
}

.section {
  margin-top: 24rpx;
  padding: 30rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 16rpx 42rpx rgba(17, 24, 39, 0.07);
  backdrop-filter: blur(24rpx) saturate(160%);
  -webkit-backdrop-filter: blur(24rpx) saturate(160%);
}

.section__header {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.section__hint {
  display: block;
  margin: -10rpx 0 22rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.4;
  text-align: center;
}

.section__title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.section__meta {
  color: #98a2b3;
  font-size: 21rpx;
  text-transform: uppercase;
}

.target-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.role-card {
  padding: 24rpx;
  border-radius: 14rpx;
  background: rgba(248, 250, 252, 0.52);
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  text-align: center;
  transition: transform 160ms ease, opacity 160ms ease;
}

.role-card__head {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.role-card__icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #111827;
  color: #f59e0b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.role-card__title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.role-card__desc {
  display: block;
  margin-top: 14rpx;
  color: #475467;
  font-size: 26rpx;
  line-height: 1.65;
}

.mini-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.mini-tag {
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(236, 253, 245, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.66);
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 700;
}

.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.highlight {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 14rpx;
  text-align: left;
}

.highlight__mark {
  width: 12rpx;
  height: 12rpx;
  margin-top: 16rpx;
  border-radius: 50%;
  background: #f59e0b;
  flex-shrink: 0;
}

.highlight__text {
  color: #344054;
  font-size: 27rpx;
  line-height: 1.65;
}

.education {
  padding: 24rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.46);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(18rpx) saturate(155%);
  -webkit-backdrop-filter: blur(18rpx) saturate(155%);
  text-align: center;
}

.education__school {
  display: block;
  color: #111827;
  font-size: 31rpx;
  line-height: 1.5;
  font-weight: 900;
}

.education__line {
  display: block;
  margin-top: 10rpx;
  color: #475467;
  font-size: 26rpx;
  line-height: 1.6;
}

.skill-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skill {
  padding: 22rpx;
  border-radius: 16rpx;
  background: rgba(248, 250, 252, 0.56);
  border: 1rpx solid rgba(255, 255, 255, 0.74);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  transition: transform 160ms ease, opacity 160ms ease;
}

.skill__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  text-align: left;
}

.skill__name {
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
}

.skill__level {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 800;
}

.skill__right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.skill__open {
  padding: 5rpx 8rpx;
  border-radius: 6rpx;
  background: rgba(15, 118, 110, 0.1);
  color: #0f766e;
  font-size: 18rpx;
  font-weight: 900;
}

.skill__bar {
  height: 14rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(229, 231, 235, 0.72);
  box-shadow: inset 0 1rpx 3rpx rgba(17, 24, 39, 0.12);
}

.skill__bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #f59e0b, #0f766e);
}

.skill__desc {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: left;
}

.section--dark {
  background: rgba(17, 24, 39, 0.86);
  border-color: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.section--dark__title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
}

.fit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.fit-item {
  color: #e5e7eb;
  font-size: 26rpx;
  line-height: 1.65;
  text-align: center;
}

.dark-action {
  margin-top: 26rpx;
  height: 84rpx;
  border-radius: 14rpx;
  background: rgba(245, 158, 11, 0.86);
  border: 1rpx solid rgba(255, 225, 164, 0.48);
  color: #111827;
  font-size: 28rpx;
  line-height: 84rpx;
  font-weight: 900;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.42), 0 14rpx 34rpx rgba(0, 0, 0, 0.18);
  transition: transform 160ms ease, opacity 160ms ease;
}

.dark-action::after {
  border: 0;
}

@import 'index-wxa-auto-dark.wxss'

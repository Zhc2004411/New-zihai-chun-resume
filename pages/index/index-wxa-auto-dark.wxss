@media (prefers-color-scheme: dark) {
    .page {
        background: rgb(0, 0, 0);
    }

    .hero {
        background: rgb(239, 246, 255);
    }

    .hero__content {
        color: rgb(17, 17, 17);
    }

    .profile-chip {
        background: rgba(17, 17, 17, 0.16);
    }

    .profile-chip__avatar {
        background: rgb(124, 56, 0);
        color: rgb(239, 246, 255);
    }

    .profile-chip__text {
        color: rgb(20, 21, 22);
    }

    .hero__role {
        color: rgb(47, 33, 0);
    }

    .hero__slogan {
        color: rgb(33, 35, 37);
    }

    .action {
        background: rgba(17, 17, 17, 0.74);
        color: rgb(239, 246, 255);
    }

    .action--primary {
        background: rgba(124, 56, 0, 0.82);
        border-color: rgba(51, 33, 0, 0.56);
    }

    .metric {
        background: rgba(17, 17, 17, 0.72);
    }

    .metric--salary {
        background: rgba(239, 246, 255, 0.84);
        border-color: rgba(17, 17, 17, 0.22);
    }

    .metric__value {
        color: rgb(239, 246, 255);
    }

    .metric--salary .metric__value {
        color: rgb(124, 56, 0);
    }

    .metric__label {
        color: rgb(130, 140, 162);
    }

    .metric--salary .metric__label {
        color: rgb(33, 35, 37);
    }

    .section {
        background: rgba(17, 17, 17, 0.7);
    }

    .section__hint {
        color: rgb(130, 140, 162);
    }

    .section__title {
        color: rgb(239, 246, 255);
    }

    .section__meta {
        color: rgb(83, 92, 108);
    }

    .role-card {
        background: rgba(20, 21, 23, 0.52);
    }

    .role-card__icon {
        background: rgb(239, 246, 255);
        color: rgb(124, 56, 0);
    }

    .role-card__title {
        color: rgb(239, 246, 255);
    }

    .role-card__desc {
        color: rgb(158, 172, 194);
    }

    .mini-tag {
        background: rgba(10, 25, 19, 0.7);
        color: rgb(72, 161, 152);
    }

    .highlight__mark {
        background: rgb(124, 56, 0);
    }

    .highlight__text {
        color: rgb(182, 195, 219);
    }

    .education {
        background: rgba(17, 17, 17, 0.46);
    }

    .education__school {
        color: rgb(239, 246, 255);
    }

    .education__line {
        color: rgb(158, 172, 194);
    }

    .skill {
        background: rgba(20, 21, 23, 0.56);
    }

    .skill__name {
        color: rgb(239, 246, 255);
    }

    .skill__level {
        color: rgb(72, 161, 152);
    }

    .skill__open {
        background: rgba(72, 161, 152, 0.1);
        color: rgb(72, 161, 152);
    }

    .skill__bar {
        background: rgba(33, 35, 37, 0.72);
    }

    .skill__bar-fill {
        background: rgb(0, 0, 0);
    }

    .skill__desc {
        color: rgb(130, 140, 162);
    }

    .section--dark {
        background: rgba(239, 246, 255, 0.86);
        border-color: rgba(17, 17, 17, 0.18);
        color: rgb(17, 17, 17);
    }

    .fit-item {
        color: rgb(33, 35, 37);
    }

    .dark-action {
        background: rgba(124, 56, 0, 0.86);
        color: rgb(239, 246, 255);
    }
}

.page {
  min-height: 100vh;
  padding: 40rpx 24rpx 64rpx;
  background: linear-gradient(180deg, #e7edf4 0%, #f8fafc 50%, #eef4f7 100%);
}

.card {
  padding: 44rpx 30rpx;
  border-radius: 26rpx;
  background: rgba(17, 24, 39, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  color: #ffffff;
  text-align: center;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.18), 0 24rpx 58rpx rgba(17, 24, 39, 0.2);
  backdrop-filter: blur(24rpx) saturate(140%);
  -webkit-backdrop-filter: blur(24rpx) saturate(140%);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #f59e0b;
  color: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 900;
}

.name {
  display: block;
  margin-top: 22rpx;
  font-size: 46rpx;
  line-height: 1.2;
  font-weight: 900;
}

.role {
  display: block;
  margin-top: 10rpx;
  color: #d1d5db;
  font-size: 27rpx;
  line-height: 1.5;
}

.target-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
}

.target {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #fde68a;
  font-size: 23rpx;
  font-weight: 700;
}

.section {
  margin-top: 24rpx;
  padding: 30rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 16rpx 42rpx rgba(17, 24, 39, 0.07);
  backdrop-filter: blur(24rpx) saturate(160%);
  -webkit-backdrop-filter: blur(24rpx) saturate(160%);
  text-align: center;
}

.section__title {
  display: block;
  margin-bottom: 20rpx;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.contact-line {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2f7;
  border-radius: 14rpx;
  transition: transform 160ms ease, opacity 160ms ease, background 160ms ease;
}

.contact-line--active {
  background: rgba(248, 250, 252, 0.36);
}

.contact-line:last-child {
  border-bottom: 0;
}

.label {
  color: #667085;
  font-size: 26rpx;
}

.value {
  color: #111827;
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
  word-break: break-all;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.button {
  height: 88rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.74);
  color: #111827;
  font-size: 29rpx;
  line-height: 88rpx;
  font-weight: 900;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 16rpx 38rpx rgba(17, 24, 39, 0.08);
  backdrop-filter: blur(18rpx) saturate(150%);
  -webkit-backdrop-filter: blur(18rpx) saturate(150%);
  transition: transform 160ms ease, opacity 160ms ease;
}

.button::after {
  border: 0;
}

.button--primary {
  background: rgba(245, 158, 11, 0.84);
  border-color: rgba(255, 225, 164, 0.58);
}

.note {
  margin-top: 24rpx;
  padding: 30rpx;
  border-radius: 22rpx;
  background: rgba(236, 253, 245, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.86), 0 16rpx 40rpx rgba(17, 24, 39, 0.07);
  backdrop-filter: blur(20rpx) saturate(155%);
  -webkit-backdrop-filter: blur(20rpx) saturate(155%);
  text-align: center;
}

.note__title {
  display: block;
  color: #0f766e;
  font-size: 30rpx;
  font-weight: 900;
}

.note__text {
  display: block;
  margin-top: 10rpx;
  color: #344054;
  font-size: 26rpx;
  line-height: 1.65;
}
